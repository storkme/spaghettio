{
  "providers": {
    "llama": {
      "baseUrl": "http://llama-host:${LLAMA_PORT}/v1",
      "api": "openai-completions",
      "apiKey": "not-needed",
      "models": [
        {
          "id": "${LLAMA_MODEL}",
          "name": "${LLAMA_MODEL} (local)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": ${LLAMA_CONTEXT},
          "maxTokens": ${LLAMA_MAX_TOKENS},
          "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0}
        }
      ]
    }
  }
}
