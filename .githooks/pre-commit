#!/bin/sh
# Pre-commit hook: clippy + tsc
# Activate with: git config core.hooksPath .githooks
# Bypass with: git commit --no-verify

set -e

# --- Rust: clippy (if any Rust files are staged) ---
if git diff --cached --name-only | grep -qE '\.rs$|Cargo\.toml|Cargo\.lock'; then
  if command -v cargo >/dev/null 2>&1; then
    cargo clippy -p spaghettio_core -- -D warnings || {
      echo "cargo clippy failed — fix warnings before committing"
      exit 1
    }
  fi
fi

# --- TypeScript: tsc --noEmit (if web/ files are staged) ---
if git diff --cached --name-only | grep -qE '^web/src/'; then
  if [ -f web/node_modules/.bin/tsc ]; then
    (cd web && npx tsc --noEmit) || {
      echo "TypeScript check failed — fix type errors before committing"
      exit 1
    }
  else
    echo "warning: web/node_modules not installed — skipping TypeScript check"
  fi
fi
